(defpoll current_quote :interval "1000s"
  "sh -lc 'sed -n \"$(( (RANDOM % $(wc -l < ~/Documents/quotes.txt)) + 1 ))p\" ~/Documents/quotes.txt'"
)



(defwindow quote
  :monitor 0
  :stacking "bg"
  :windowtype "normal"
  :exclusive false
  :focusable false
  :wm-ignore true
  :bgcolor "transparent"
  :geometry (geometry
    :width "100%"
    :height "8%"
    :anchor "bottom center")
 (box
    (label :class "quote-text" :text current_quote)))
